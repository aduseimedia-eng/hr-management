# ============================================================
# HRConnect — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hrconnect
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production
JWT_EXPIRES=8h

# Payroll rates (as decimals)
DEDUCTION_RATE=0.10
ALLOWANCE_RATE=0.05

# Attendance (hour at which clock-in is considered late, 24h)
LATE_THRESHOLD_HOUR=9
